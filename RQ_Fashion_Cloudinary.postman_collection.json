{
  "info": {
    "name": "RQ Fashion - Cloudinary Integration",
    "description": "Test collection for Cloudinary image upload endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product with Images",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Premium Cotton T-Shirt",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "High quality cotton t-shirt with comfortable fit",
                  "type": "text"
                },
                {
                  "key": "price",
                  "value": "2999",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "{{categoryId}}",
                  "type": "text"
                },
                {
                  "key": "sku",
                  "value": "TSHIRT-001",
                  "type": "text"
                },
                {
                  "key": "stock",
                  "value": "100",
                  "type": "text"
                },
                {
                  "key": "images",
                  "type": "file",
                  "src": "image1.jpg"
                },
                {
                  "key": "images",
                  "type": "file",
                  "src": "image2.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "Update Product Images",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Updated Product Name",
                  "type": "text"
                },
                {
                  "key": "images",
                  "type": "file",
                  "src": "new_image.jpg"
                },
                {
                  "key": "existingImages",
                  "value": "[\"https://res.cloudinary.com/.../existing1.jpg\"]",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category with Image",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Summer Collection 2024",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Best summer dresses and tops",
                  "type": "text"
                },
                {
                  "key": "season",
                  "value": "summer",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": "category-image.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories"]
            }
          }
        },
        {
          "name": "Update Category Image",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Updated Category",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": "new-category-image.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Hero Slider",
      "item": [
        {
          "name": "Create Hero Slide",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Summer Sale 2024",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Up to 50% off on selected items",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": "hero-image.jpg"
                },
                {
                  "key": "isActive",
                  "value": "true",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/hero-slider",
              "host": ["{{baseUrl}}"],
              "path": ["api", "hero-slider"]
            }
          }
        }
      ]
    },
    {
      "name": "User Avatar",
      "item": [
        {
          "name": "Update User Avatar",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "type": "file",
                  "src": "user-avatar.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/avatar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "avatar"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": ""
    }
  ]
}
